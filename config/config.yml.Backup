# WebSSH — Konfigurationsdatei
# Kopieren nach config/config.yml und anpassen.
# YAML-Kommentare beginnen mit #
# Zeilen können durch ein vorangestelltes # auskommentiert werden.


# ── Server ────────────────────────────────────────────────────────────────────

# Netzwerk-Interface auf dem der Server lauscht.
# 0.0.0.0 = alle Interfaces, 127.0.0.1 = nur lokal
host: "0.0.0.0"

# Port des WebSSH-Servers
port: 8282

# Log-Level: DEBUG | INFO | WARNING | ERROR
# WARNING: nur Verbindungs- und Fehlermeldungen (empfohlen für Produktion)
# DEBUG:   alle Meldungen inkl. aiohttp-Internals (nur für Entwicklung)
log_level: "WARNING"


# ── Pfade ─────────────────────────────────────────────────────────────────────

paths:
  # Verzeichnis mit SSH-Private-Keys.
  # Im Server-Formular wird nur der Dateiname gespeichert,
  # dieser Pfad wird beim Verbindungsaufbau automatisch vorangestellt.
  # Es werden nur Dateien OHNE Dateiendung angezeigt (Private Keys).
  ssh_keys: "/root/.ssh"

  # Zusätzliche Dateinamen die im Key-Dropdown nicht erscheinen sollen.
  # authorized_keys, known_hosts und config sind immer ausgeschlossen.
  # -> ssh_keys_exclude: "deploy_key, backup_key"

  # Verzeichnis mit Schriftart-Dateien (.ttf, .otf, .woff, .woff2).
  # Leer lassen → Standard: static/fonts/ im WebSSH-Verzeichnis.
  # Für Docker-Einsatz empfiehlt sich ein externes Verzeichnis.
  # -> fonts: "/opt/webssh/fonts"


# ── Schriftarten ──────────────────────────────────────────────────────────────

fonts:
  # Terminal-Fenster
  # Verfügbare Fonts werden aus static/fonts/ gelesen.
  # Bold-Variante: Dateiname mit Suffix -Bold oder _Bold (optional).
  terminal:
    family: "DejaVuSansMono"                    # muss mit Dateiname in static/fonts/ übereinstimmen
    size: 24                                    # Schriftgröße in Pixel
    file: "fonts/DejaVuSansMono.ttf"            # Pfad relativ zu static/
    file_bold: "fonts/DejaVuSansMono-Bold.ttf"  # leer lassen wenn kein Bold vorhanden

  # Launcher-Dialog (Server-Auswahl, Kategorien, Suchfeld)
  ui:
    size: 16

  # Keyboard-Toolbar (Strg- und F-Key-Buttons)
  toolbar:
    size: 25


# ── Terminal-Verhalten ────────────────────────────────────────────────────────

terminal:
  # Tab automatisch schließen wenn die SSH-Session endet (z.B. durch exit)
  close_on_disconnect: true

  # Sekunden Verzögerung vor dem automatischen Schließen (0 = sofort)
  # Wird nur ausgewertet wenn close_on_disconnect: true
  close_delay: 3

  # Aktive Sessions im Launcher-Dialog anzeigen
  # false = Abschnitt "Aktive Sessions" ausblenden
  show_active_sessions: true


# ── Session-Persistenz ────────────────────────────────────────────────────────

sessions:
  # SSH-Sessions über Browser-Reload hinaus am Leben erhalten
  persist: true

  # session_mode steuert Sichtbarkeit von Sessions:
  #   single_user — alle Sessions global sichtbar (für einen Benutzer,
  #                 z.B. nahtloser Wechsel zwischen zwei Rechnern)
  #   multi_user  — jeder Browser sieht nur seine eigenen Sessions
  #                 (anhand der client_id im localStorage)
  session_mode: "single_user"

  # Sekunden bis eine verwaiste Session (kein WebSocket) automatisch beendet wird
  # 86400 = 24 Stunden
  reconnect_timeout: 86400

  # Maximale Größe des Scrollback-Buffers pro Session in Bytes
  # Wird beim Reconnect an den Browser geschickt
  # 524288 = 512 KB
  buffer_size: 524288


# ── Server-Presets ────────────────────────────────────────────────────────────
# Jeder Eintrag erscheint als Karte im Launcher-Dialog.
# Pflichtfelder: title, host, username + (private_key oder password)
# Optionale Felder: category, port, font

presets:

  - title: "Service-Instanz"
    category: "Produktion"        # Gruppierung im Launcher (optional)
    host: "1192.168.1.43"
    port: 22                      # Standard: 22
    username: "root"
    private_key: "id_ansible"     # Nur Dateiname — paths.ssh_keys wird vorangestellt

  - title: "nginx"
    category: "Produktion"        # Gruppierung im Launcher (optional)
    host: "192.168.1.46"
    port: 22                      # Standard: 22
    username: "root"
    private_key: "id_ansible"     # Nur Dateiname — paths.ssh_keys wird vorangestellt

  - title: "iobroker (root)"
    category: "Smarthome"        # Gruppierung im Launcher (optional)
    host: "192.168.1.21"
    port: 22                      # Standard: 22
    username: "root"
    private_key: "id_ansible"     # Nur Dateiname — paths.ssh_keys wird vorangestellt

  - title: "iobroker (User)"
    category: "Smarthome"        # Gruppierung im Launcher (optional)
    host: "192.168.1.21"
    port: 22                      # Standard: 22
    username: "iobroker"
    private_key: "id_ansible"     # Nur Dateiname — paths.ssh_keys wird vorangestellt

  - title: "Homematic"
    category: "Smarthome"        # Gruppierung im Launcher (optional)
    host: "192.168.1.20"
    port: 22                      # Standard: 22
    username: "iobroker"
    password: "holk22,62C!"     # Nur Dateiname — paths.ssh_keys wird vorangestellt

  - title: "Grafana"
    category: "Smarthome"        # Gruppierung im Launcher (optional)
    host: "10.0.1.101"
